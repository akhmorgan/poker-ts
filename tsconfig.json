{
  "compilerOptions": {
    "module": "ESNext",       // 👈 this is critical
    "target": "ESNext",       // or at least ES2017+
    "moduleResolution": "node", // helps Vite + ESM interop
    "outDir": "dist",
    "declaration": true,
    "sourceMap": true,
    "allowSyntheticDefaultImports": true,
    "strictNullChecks": true,
    "strictPropertyInitialization": true,
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "*": [
        "node_modules/"
      ],
      "types/*": [
        "src/types/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "test/**/*.spec.ts"
  ]
}